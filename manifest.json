{
  "manifest_version": 3,
  "minimum_chrome_version": "110",
  "name": "__MSG_extName__",
  "version": "2.96.3",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "notifications",
    "alarms",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://api.pinboard.in/*",
    "https://pinboard.in/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/pin-default-16.png",
      "32": "icons/pin-default-32.png",
      "48": "icons/pin-default-48.png",
      "128": "icons/pin-default-128.png"
    }
  },
  "icons": {
    "16": "icons/pin-default-16.png",
    "32": "icons/pin-default-32.png",
    "48": "icons/pin-default-48.png",
    "128": "icons/pin-default-128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://pinboard.in/*",
        "https://*.pinboard.in/*"
      ],
      "js": [
        "pinboard-themes.js",
        "pinboard-style.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://pinboard.in/*",
        "https://*.pinboard.in/*"
      ],
      "js": [
        "pinboard-sort.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "MacCtrl+B"
      },
      "description": "__MSG_cmdOpenPopup__"
    },
    "quick_save": {
      "suggested_key": {
        "default": "Alt+Shift+B",
        "mac": "MacCtrl+Shift+B"
      },
      "description": "__MSG_cmdQuickSave__"
    },
    "read_later": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "MacCtrl+Shift+R"
      },
      "description": "__MSG_cmdReadLater__"
    },
    "markdown_preview": {
      "suggested_key": {
        "default": "Alt+Shift+M",
        "mac": "MacCtrl+Shift+M"
      },
      "description": "__MSG_cmdMarkdownPreview__"
    },
    "save_tabset": {
      "description": "__MSG_cmdSaveTabSet__"
    }
  }
}
