{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.22",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.pinboard.in/*",
    "https://pinboard.in/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.deepseek.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://api.minimax.chat/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://api.mistral.ai/*",
    "https://api.cohere.com/*",
    "https://api.siliconflow.cn/*",
    "https://open.bigmodel.cn/*",
    "https://api.moonshot.cn/*",
    "https://r.jina.ai/*"
  ],
  "optional_host_permissions": [
    "*://*/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/pin-default-16.png",
      "32": "icons/pin-default-32.png",
      "48": "icons/pin-default-48.png",
      "128": "icons/pin-default-128.png"
    }
  },
  "icons": {
    "16": "icons/pin-default-16.png",
    "32": "icons/pin-default-32.png",
    "48": "icons/pin-default-48.png",
    "128": "icons/pin-default-128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://pinboard.in/*",
        "https://*.pinboard.in/*"
      ],
      "js": [
        "pinboard-style.js"
      ],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "MacCtrl+B"
      },
      "description": "__MSG_cmdOpenPopup__"
    },
    "quick_save": {
      "suggested_key": {
        "default": "Alt+Shift+B",
        "mac": "MacCtrl+Shift+B"
      },
      "description": "__MSG_cmdQuickSave__"
    },
    "read_later": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "MacCtrl+Shift+R"
      },
      "description": "__MSG_cmdReadLater__"
    }
  }
}
