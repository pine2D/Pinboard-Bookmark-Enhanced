{
  "meta": {
    "id": "paper-ink",
    "name": "Paper & Ink",
    "mode": "light",
    "description": "Sprint 3 migration: warm serif reading experience with cream paper background and ink-blue titles. Source: pinboard-themes.js §paper-ink."
  },
  "layout": {
    "mode": "classic-list",
    "max-width": "1030px",
    "bookmark-style": "flat",
    "right-bar": "visible"
  },
  "palette": {
    "bg":             "#faf8f5",
    "bg-surface":     "#f5f0e8",
    "fg":             "#2c2c2c",
    "fg-strong":      "#6b4c3b",
    "muted":          "#6b4c3b",
    "muted-soft":     "#999999",
    "border":         "#d4c5a9",
    "border-strong":  "#d4c5a9",
    "border-soft":    "#e8dfd0",
    "accent":         "#1a3a5c",
    "accent-hover":   "#2a5a8c",
    "accent-soft":    "#f5f0e8",
    "accent-alpha":   "rgba(26,58,92,0.25)",
    "input-bg":       "#fefdfb",
    "private-bg":     "#fdf6e3",
    "private-accent": "#d4c5a9",
    "selection-bg":   "#1a3a5c",
    "selection-fg":   "#faf8f5",
    "tag-bg":         "transparent",
    "tag-fg":         "#8b4513",
    "row-hover":      "#ede4d0",
    "destroy":        "#c0392b",
    "btn-bg":         "#6b4c3b",
    "btn-fg":         "#faf8f5",
    "success":        "#8b4513",
    "success-hover":  "#a0522d",
    "url-link-bg":    "#f5f0e8",
    "url-link-fg":    "#a0522d",
    "link-hover":     "#2a5a8c",
    "link-visited":   "#1a3a5c",
    "focus-ring":     "#8b6c5b",
    "unread":         "#c0392b"
  },
  "typo": {
    "family": "\"Georgia\", \"Noto Serif\", \"Source Serif Pro\", serif",
    "size-base": "14px",
    "size-lg":   "16px",
    "size-sm":   "12px",
    "size-xs":   "11px",
    "line-height": 1.7,
    "weight-body": 400,
    "weight-heading": 700
  },
  "space": {
    "unit":           "4px",
    "bookmark-gap":   "6px",
    "main-padding":   "14px",
    "sub-banner-y":   "8px",
    "right-bar-gap":  "16px",
    "form-gap":       "8px"
  },
  "radius": {
    "sm": "2px",
    "md": "4px",
    "lg": "3px"
  },
  "border": {
    "width": "1px",
    "style": "solid"
  },
  "ext": {
    "private-style": "border-left",
    "private-border-width": "3px"
  }
}
