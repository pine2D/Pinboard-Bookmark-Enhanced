{
  "meta": {
    "id": "gruvbox-dark",
    "name": "Gruvbox Dark",
    "mode": "dark",
    "description": "Sprint 3 migration sample: Retro warm dark theme with earthy tones (IBM Plex Sans + aurora accents). Source: pinboard-themes.js §gruvbox-dark."
  },
  "layout": {
    "mode": "classic-list",
    "max-width": "1030px",
    "bookmark-style": "flat",
    "right-bar": "visible"
  },
  "palette": {
    "bg":             "#282828",
    "bg-surface":     "#3c3836",
    "fg":             "#ebdbb2",
    "fg-strong":      "#fbf1c7",
    "muted":          "#a89984",
    "muted-soft":     "#665c54",
    "border":         "#504945",
    "border-strong":  "#504945",
    "border-soft":    "#504945",
    "accent":         "#83a598",
    "accent-hover":   "#d3869b",
    "accent-soft":    "#3c3836",
    "accent-alpha":   "rgba(131,165,152,0.3)",
    "input-bg":       "#282828",
    "private-bg":     "#3c3836",
    "private-accent": "#fabd2f",
    "selection-bg":   "#665c54",
    "selection-fg":   "#fbf1c7",
    "tag-bg":         "transparent",
    "tag-fg":         "#b8bb26",
    "row-hover":      "#3c3836",
    "destroy":        "#fb4934",
    "btn-bg":         "#83a598",
    "btn-fg":         "#282828",
    "success":        "#458588",
    "success-hover":  "#689d6a",
    "url-link-bg":    "#32302f",
    "url-link-fg":    "#fabd2f",
    "link-hover":     "#d3869b",
    "link-visited":   "#83a598",
    "focus-ring":     "#83a598",
    "unread":         "#fb4934"
  },
  "typo": {
    "family": "\"IBM Plex Sans\", \"Inter\", -apple-system, sans-serif",
    "size-base": "13px",
    "size-lg":   "15px",
    "size-sm":   "12px",
    "size-xs":   "11px",
    "line-height": 1.5,
    "weight-body": 450,
    "weight-heading": 700
  },
  "space": {
    "unit":           "4px",
    "bookmark-gap":   "4px",
    "main-padding":   "12px",
    "sub-banner-y":   "8px",
    "right-bar-gap":  "12px",
    "form-gap":       "8px"
  },
  "radius": {
    "sm": "2px",
    "md": "0",
    "lg": "0"
  },
  "border": {
    "width": "2px",
    "style": "solid"
  },
  "ext": {
    "private-style": "border-left",
    "private-border-width": "3px"
  },
  "overrides": {
    "css": "/* Gruvbox-specific tag hash glyph */\na.tag::before { content: \"#\" !important; }\n"
  }
}
