{
  "meta": {
    "id": "terminal",
    "name": "Terminal",
    "mode": "dark",
    "description": "Sprint 3 migration sample: Retro CRT green-on-black hacker aesthetic (monospace + dashed borders + prompt glyphs). Source: pinboard-themes.js §terminal."
  },
  "layout": {
    "mode": "classic-list",
    "max-width": "1030px",
    "bookmark-style": "flat",
    "right-bar": "visible"
  },
  "palette": {
    "bg":             "#0a0a0a",
    "bg-surface":     "#111111",
    "fg":             "#33ff33",
    "fg-strong":      "#66ff66",
    "muted":          "#22aa22",
    "muted-soft":     "#336633",
    "border":         "#33ff3340",
    "border-strong":  "#33ff3380",
    "border-soft":    "#33ff3325",
    "accent":         "#33ff33",
    "accent-hover":   "#66ff66",
    "accent-soft":    "#1a3a1a",
    "accent-alpha":   "rgba(51,255,51,0.3)",
    "input-bg":       "#111111",
    "private-bg":     "#0a0a0a",
    "private-accent": "#cccc00",
    "selection-bg":   "#33ff3340",
    "selection-fg":   "#ffffff",
    "tag-bg":         "transparent",
    "tag-fg":         "#00cccc",
    "row-hover":      "#0f2a0f",
    "destroy":        "#ff3333",
    "btn-bg":         "#1a3a1a",
    "btn-fg":         "#33ff33",
    "success":        "#003300",
    "success-hover":  "#005500",
    "url-link-bg":    "#0d1a0d",
    "url-link-fg":    "#cccc00",
    "link-hover":     "#66ff66",
    "link-visited":   "#33ff33",
    "focus-ring":     "#33ff33",
    "unread":         "#ff3333"
  },
  "typo": {
    "family": "\"Fira Code\", \"Cascadia Code\", \"Consolas\", monospace",
    "size-base": "13px",
    "size-lg":   "14px",
    "size-sm":   "12px",
    "size-xs":   "11px",
    "line-height": 1.5,
    "weight-body": 400,
    "weight-heading": 700
  },
  "space": {
    "unit":           "4px",
    "bookmark-gap":   "4px",
    "main-padding":   "12px",
    "sub-banner-y":   "8px",
    "right-bar-gap":  "12px",
    "form-gap":       "8px"
  },
  "radius": {
    "sm": "4px",
    "md": "4px",
    "lg": "3px"
  },
  "border": {
    "width": "1px",
    "style": "solid"
  },
  "ext": {
    "private-style": "border-left",
    "private-border-width": "2px"
  },
  "overrides": {
    "css": "/* Terminal-specific decorative glyphs (CRT prompt markers) */\na.bookmark_title::before { content: \"> \" !important; color: #33ff3380 !important; }\na.tag::before { content: \"#\" !important; }\n.settings_heading::before { content: \"$ \" !important; }\n#main_column form[name=\"sort\"] table a.bundle::before { content: \"> \" !important; opacity: 0.6 !important; }\n"
  }
}
