{
  "meta": {
    "id": "solarized-dark",
    "name": "Solarized Dark",
    "mode": "dark",
    "description": "Sprint 3 migration: Ethan Schoonover Solarized Dark — base03 ink + ANSI accent rainbow. Source: pinboard-themes.js §solarized-dark."
  },
  "layout": {
    "mode": "classic-list",
    "max-width": "1030px",
    "bookmark-style": "card",
    "right-bar": "visible"
  },
  "palette": {
    "bg":             "#002b36",
    "bg-surface":     "#073642",
    "fg":             "#839496",
    "fg-strong":      "#93a1a1",
    "muted":          "#586e75",
    "muted-soft":     "#586e75",
    "border":         "#094b5a",
    "border-strong":  "#586e75",
    "border-soft":    "#094b5a",
    "accent":         "#268bd2",
    "accent-hover":   "#2aa198",
    "accent-soft":    "#073642",
    "accent-alpha":   "rgba(38,139,210,0.25)",
    "input-bg":       "#073642",
    "private-bg":     "#073642",
    "private-accent": "#b58900",
    "selection-bg":   "#0a4a5a",
    "selection-fg":   "#eee8d5",
    "tag-bg":         "transparent",
    "tag-fg":         "#2aa198",
    "row-hover":      "#073642",
    "destroy":        "#dc322f",
    "btn-bg":         "#268bd2",
    "btn-fg":         "#fdf6e3",
    "success":        "#859900",
    "success-hover":  "#2aa198",
    "url-link-bg":    "#073642",
    "url-link-fg":    "#b58900",
    "link-hover":     "#2aa198",
    "link-visited":   "#268bd2",
    "focus-ring":     "#268bd2",
    "unread":         "#dc322f"
  },
  "typo": {
    "family": "\"Inter\", -apple-system, sans-serif",
    "size-base": "13px",
    "size-lg":   "15px",
    "size-sm":   "12px",
    "size-xs":   "11px",
    "line-height": 1.5,
    "weight-body": 400,
    "weight-heading": 700
  },
  "space": {
    "unit":           "4px",
    "bookmark-gap":   "6px",
    "main-padding":   "12px",
    "sub-banner-y":   "8px",
    "right-bar-gap":  "12px",
    "form-gap":       "8px"
  },
  "radius": {
    "sm": "2px",
    "md": "4px",
    "lg": "2px"
  },
  "border": {
    "width": "1px",
    "style": "solid"
  },
  "ext": {
    "private-style": "border-left",
    "private-border-width": "2px"
  }
}
