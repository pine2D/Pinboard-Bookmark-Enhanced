{
  "meta": {
    "id": "github-light",
    "name": "GitHub Light",
    "mode": "light",
    "description": "Pilot: extract an existing shipped theme into the tokens+composer architecture to validate Sprint 2. Source: pinboard-themes.js §github-light (line 2510)."
  },
  "layout": {
    "mode": "classic-list",
    "max-width": "1030px",
    "bookmark-style": "card",
    "right-bar": "visible"
  },
  "palette": {
    "bg":             "#f6f8fa",
    "bg-surface":     "#ffffff",
    "fg":             "#1f2328",
    "muted":          "#656d76",
    "muted-soft":     "#8c959f",
    "border":         "#d0d7de",
    "accent":         "#0969da",
    "accent-hover":   "#0550ae",
    "accent-alpha":   "rgba(9,105,218,0.2)",
    "accent-soft":    "#ddf4ff",
    "input-bg":       "#ffffff",
    "private-bg":     "#ffffff",
    "private-accent": "#bf8700",
    "selection-bg":   "#ddf4ff",
    "selection-fg":   "#1f2328",
    "tag-bg":         "#ddf4ff",
    "tag-fg":         "#0550ae",
    "row-hover":      "#f6f8fa",
    "destroy":        "#cf222e",
    "btn-bg":         "#0969da",
    "btn-fg":         "#ffffff",
    "success":        "#2da44e",
    "success-hover":  "#2c974b",
    "url-link-bg":    "#fff8c5",
    "url-link-fg":    "#bf8700",
    "link-hover":     "#0550ae",
    "link-visited":   "#0969da",
    "focus-ring":     "#0969da"
  },
  "typo": {
    "family": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Noto Sans\", Helvetica, Arial, sans-serif",
    "size-base": "13px",
    "size-lg":   "15px",
    "size-sm":   "12px",
    "size-xs":   "11px",
    "line-height": 1.5,
    "weight-body": 400,
    "weight-heading": 600
  },
  "space": {
    "unit":           "4px",
    "bookmark-gap":   "6px",
    "main-padding":   "12px",
    "sub-banner-y":   "8px",
    "right-bar-gap":  "12px",
    "form-gap":       "8px",
    "gap-1":          "2px",
    "gap-2":          "6px"
  },
  "radius": {
    "sm": "3px",
    "md": "6px",
    "pill": "12px"
  },
  "border": {
    "width": "1px",
    "style": "solid"
  },
  "ext": {
    "private-style": "border-left",
    "private-border-width": "3px",
    "settings-tab-selected-border-width": "2px"
  }
}
