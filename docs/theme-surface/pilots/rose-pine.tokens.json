  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px"
  },
  "border": {
    "width": "1px",
    "style": "solid"
  },
  "ext": {
    "private-style": "border-left",
    "private-border-width": "3px"
  }
