  "state_hooks": {
    "description": "Every surface must declare which of these states it needs. Validator checks coverage.",
    "all_states": ["default", "hover", "focus-visible", "active", "selected", "checked", "disabled", "visited", "placeholder", "::selection", "::-moz-selection"],
    "selection_css": "::selection (+ ::-moz-selection for Firefox compat)"
  }
