      "scope": "bare"
    }
  },

  "inline_base_rules": [
    {
      "id": "override.tr-onmouseover-yellow",
      "applies_to": ["right_bar.table.row", "bundles.table"],
      "reason": "Pinboard writes inline style.background on mouseover/mouseout. CSS !important wins over inline style.",
      "selector": "#right_bar table tr[onmouseover], #main_column table tr[onmouseover]",
      "rule_default": "background: transparent !important;",
      "rule_hover": "background: var(--pinboard-row-hover) !important;"
    },
    {
      "id": "override.bookmark-separator",
      "applies_to": ["bookmark.item"],
      "reason": "Pinboard injects `border-top:1px dotted #aaa` inline on each bookmark. Token it.",
      "selector": "#main_column .bookmark[style*='border-top']",
      "rule": "border-top: var(--pinboard-border-hairline) !important;"
    },
    {
      "id": "override.private-bg",
      "applies_to": ["bookmark.private"],
      "reason": "Pinboard inline `background:#fff1f1` / `#fff4f4` for private — replace with themed token.",
      "selector": ".bookmark.private[style*='background'], .bookmark[style*='#fff1f1'], .bookmark[style*='#fff4f4']",
      "rule": "background: var(--pinboard-private-bg) !important;"
    },
    {
      "id": "override.sub-banner-count-color",
      "applies_to": ["sub_banner.counts"],
      "reason": "Pinboard hardcodes `color:#aa5511` on count spans.",
      "selector": "#sub_banner [style*='#aa5511'], .bookmark_count[style*='color']",
      "rule": "color: var(--pinboard-accent) !important;"
    },
    {
      "id": "override.muted-aaa",
      "applies_to": ["bookmark.edit_links", "bookmark.url_display"],
      "reason": "Widespread inline `color:#aaa` for muted text.",
      "selector": "[style*='color:#aaa'], [style*='color: #aaa']",
      "rule": "color: var(--pinboard-muted) !important;"
    },
    {
      "id": "override.bundle-table-width",
      "applies_to": ["bundles.table"],
      "reason": "Inline `style=\"width:830px\"` on bundles table breaks narrow viewports.",
      "selector": "#main_column table[style*='width:830']",
      "rule": "width: 100% !important; max-width: 100% !important;"
    },
    {
      "id": "override.bundle-slot-input",
      "applies_to": ["bundles.slot_input"],
      "reason": "Inline `border:1px dotted #bbb;width:20px` on every bundle slot input.",
      "selector": "input[type=\"text\"][name^='id_'][style*='border']",
      "rule": "border: var(--pinboard-border-width) solid var(--pinboard-border) !important; background: var(--pinboard-input-bg) !important; color: var(--pinboard-fg) !important; width: 32px !important;"
    },
    {
      "id": "override.per-page-active",
      "applies_to": ["pagination.controls"],
      "reason": "Inline `background:#ffa` marks active per-page selection.",
      "selector": "table.per_page_widget [style*='background:#ffa']",
      "rule": "background: var(--pinboard-accent-alpha) !important; color: var(--pinboard-fg) !important;"
    },
    {
      "id": "override.generic-bgcolor",
      "applies_to": ["*"],
      "reason": "Defensive: any HTML `bgcolor=` attribute still lurking.",
      "selector": "[bgcolor]",
      "rule": "background-color: transparent !important;"
    },
    {
      "id": "override.generic-html-color",
      "applies_to": ["*"],
      "reason": "Defensive: legacy font color/size attributes.",
      "selector": "font[color], font[size]",
      "rule": "color: inherit !important; font-size: inherit !important;"
    },
    {
      "id": "override.generic-fixed-width",
      "applies_to": ["*"],
      "reason": "Defensive: `width=\"NNN\"` HTML attrs on layout tables.",
      "selector": "table[width]:not([width='100%'])",
      "rule": "width: auto !important; max-width: 100% !important;"
    }
  ],

  "composers": {
    "_note": "Each composer is a function (tokens) -> css. All composers call baseLayer(tokens) first to emit :root CSS vars + inline_base_rules. The remaining emission covers the surface set below.",
    "classic-list-v2": {
      "file": "composers/classic-list-v2.mjs",
      "status": "canonical",
      "layout_mode": "classic-list",
      "selector_count": 195,
      "emits_surfaces": ["shell.page", "shell.popup", "shell.text_inherit", "banner.*", "sub_banner.*", "main.column", "bookmark.*", "right_bar.*", "tag_cloud.*", "form.*", "settings.*", "profile.*", "note.*", "bulk.*", "popup.*", "bundles.*", "pagination.*", "global.*", "misc.*"],
      "ext_tokens": ["private-style", "private-border-width"]
    },
    "dense": {
      "file": "composers/dense.mjs",
      "status": "demo",
      "layout_mode": "dense",
      "base": "classic-list (v1) with spacing compression"
    },
    "card-grid": {
      "file": "composers/card-grid.mjs",
      "status": "demo",
      "layout_mode": "card-grid",
      "notes": "CSS Grid auto-fill minmax cards"
    },
    "magazine": {
      "file": "composers/magazine.mjs",
      "status": "demo",
      "layout_mode": "magazine",
      "notes": "editorial two-column grid with hero bookmark + drop-caps"
    }
  },

  "modes": {
    "_note": "Dark mode (and other variants) are emitted by composers/compose-theme.mjs, which runs the base composer once, then re-runs it with tokens.modes.<name>.palette merged on top, prefixing every selector with modes.<name>.trigger. This is the mechanism behind Flexoki Adaptive (verified pilot: flexoki achieves 100% selector coverage, both light+dark).",
    "trigger_convention": "tokens.modes.<name>.trigger — any CSS selector string (typically 'html.pbp-dark'). Selection logic is injected by pinboard-style.js based on extension Theme setting.",
    "supported_modes": ["dark"],
    "example": {
      "tokens.modes.dark": {
        "trigger": "html.pbp-dark",
        "palette": { "bg": "#1C1B1A", "fg": "#CECDC3" }
      }
    },
    "prefixing_rules": {
      "skipped_selectors": [":root", "@-rules"],
      "preserved": "CSS comments (via placeholder swap-out during scan)",
      "comma_groups": "each fragment prefixed independently — `a, b { }` becomes `html.pbp-dark a, html.pbp-dark b { }`"
    }
  },

  "patterns": {
    "_note": "Declarative stylistic choices beyond color/font/space. Each entry selects a named design decision the composer (via composers/_patterns.mjs) knows how to emit. Patterns run BETWEEN composer defaults and tokens.overrides.css — i.e. composer baseline < patterns < overrides (escape hatch). Adding a theme-wide visual quirk? Add a pattern enum instead of dropping CSS into overrides.",
    "shape": {
      "tokens.patterns": "object — see tokens.schema.json §patterns. All keys optional; unset means composer default."
    },
    "available": {
      "tag-style": { "values": ["plain", "hash-prefix", "pill", "bracketed"], "affects": "a.tag pseudo-elements and/or radius" },
      "bookmark-title-prefix": { "values": "literal string ≤8 chars", "affects": "a.bookmark_title::before content" },
      "heading-prefix": { "values": "literal string ≤8 chars", "affects": ".settings_heading::before content" },
      "url-link-style": { "values": ["plain", "capsule", "pill", "underline"], "affects": "a.url_link chrome" },
      "private-badge": { "values": ["tint-bg", "border-left", "dashed", "stripe"], "affects": ".private marker" },
      "focus-ring": { "values": ["none", "thin-solid", "dashed", "glow"], "affects": "input/textarea/select :focus outline" },
      "shape": { "values": ["sharp", "rounded", "pill"], "affects": "macro rewrite of --pinboard-radius-* at :root" },
      "density": { "values": ["compact", "default", "roomy"], "affects": "macro rewrite of --pinboard-space-* + .bookmark padding" },
      "hover-effect": { "values": ["underline", "lift", "color-shift", "fade-bg"], "affects": ".bookmark:hover + title underline" },
      "row-divider": { "values": ["none", "hairline", "dashed", "left-accent"], "affects": ".bookmark border treatment (border-bottom rule or border-left stripe)" },
      "heading-accent": { "values": ["plain", "caps", "dashed-underline"], "affects": ".settings_heading delta: uppercase+letter-spacing OR dashed bottom rule" },
      "card-shadow": { "values": ["none", "soft", "strong"], "affects": ".bookmark box-shadow; pair with row-divider:none for card-like rows" },
      "blockquote-style": { "values": ["plain", "left-accent", "left-muted"], "affects": ".description blockquote left border + padding; width via ext.blockquote-border-width (default 3px)" },
      "banner-chrome": { "values": ["plain", "rounded", "card"], "affects": "#banner radius + padding (rounded) or bg-surface + bottom border + shadow (card); radius via ext.banner-radius" },
      "title-weight": { "values": ["normal", "medium", "semibold", "bold"], "affects": "a.bookmark_title font-weight (400/500/600/700)" },
      "tag-size": { "values": ["default", "small"], "affects": "a.tag font-size (uses typo.size-xs for small)" }
    },
    "when_to_add_new_pattern": [
      "Theme-personality rule you find in 3+ themes' overrides.css — promote it to a pattern",
      "A visual quirk you want parameterized rather than hand-coded",
      "Never add a pattern with <2 realistic enum values — single-value patterns belong in the composer baseline"
    ]
  },

  "overrides": {
    "_note": "Escape hatch for decorations the composer AND patterns can't express. composeTheme() appends tokens.overrides.css verbatim after the patterns layer. Used by terminal (CRT ::before bundle markers), modern-card (#main_column wrapper padding + checkbox accent). Most auto-generated content here is from tools/generate-overrides.mjs (byte-preservation patch for shipped CSS). Keep hand-authored overrides short — if a rule repeats across ≥3 themes, promote it to a pattern.",
    "shape": {
      "tokens.overrides.css": "string — raw CSS appended verbatim. Not validated, not mode-prefixed."
    },
    "when_to_use": [
      "Truly one-off selectors (e.g. #main_column form[name=sort] a.bundle::before — too specific for a generic pattern)",
      "Byte-preservation patches auto-generated by tools/generate-overrides.mjs (shipped-CSS drift closure)",
      "Theme-unique animations (CRT scanlines, terminal cursor blink) the composer cannot synthesize"
    ],
    "when_NOT_to_use": [
      "A rule that fits an existing pattern — use tokens.patterns instead",
      "A rule with a selector the composer already emits — that's a palette mismatch, fix tokens.palette",
      "Defensive overrides against Pinboard inline styles — those live in _base.mjs inline_base_rules"
    ]
  },

