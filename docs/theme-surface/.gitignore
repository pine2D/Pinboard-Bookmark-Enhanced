# Derivable artifacts from render-*.mjs — regenerate via `node pilots/render-all.mjs`
pilots/*.generated.css
pilots/*.generated-v2.css
pilots/*.shipped.css
pilots/*-report.json
pilots/report.json
pilots/report-v2.json
pilots/migration-matrix.json
pilots/coverage-all13.json
pilots/flexoki-report.json
pilots/nord-night-report.json
pilots/drift-matrix.json
pilots/*.apply-report.json
pilots/*.overrides-patch.css
aggregate-report.json

# Dev-time reference fixtures — contain AUTHOR'S PINBOARD ACCOUNT DATA
# (usernames in page captures, bookmark lists in raw.html, selection text in state-capture.json).
# NEVER remove these rules. See snapshots/README.md for the full threat model.
#
# NOTE: We use `snapshots/*` (not `snapshots/`) so the negation below can let
# README.md through. If the parent dir is wholly excluded, git refuses to
# descend and negation of contained files doesn't work.
snapshots/*
theme-screenshots/
# Negation: let the warning README through so it shows up in the repo.
!snapshots/README.md
